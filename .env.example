# 업비트 API 키 (실제 발급받은 키 입력)
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# 로컬 LM Studio 설정 (Gemma 모델 연동용)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# 트레이딩 및 시뮬레이션 설정 (수수료 절감 및 신호 신뢰도를 위해 60분 권장)
TRADING_INTERVAL_MINUTES=60
MAX_INVESTMENT_KRW=100000

# MOCK_MODE를 True로 설정하면 실제 업비트 주문 및 API 키 없이도 완벽한 시뮬레이션 테스트가 가능합니다.
MOCK_MODE=True

# 텔레그램 실시간 알림 봇 설정 (선택사항)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
